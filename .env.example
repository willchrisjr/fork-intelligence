# Application
# Next.js uses the same-origin proxy; the proxy talks to the versioned API.
FORK_INTELLIGENCE_ENVIRONMENT=development
FORK_INTELLIGENCE_WEB_ORIGIN=http://localhost:3000
API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=/api/v1

# Durable services
FORK_INTELLIGENCE_DATABASE_URL=postgresql+psycopg://fork_intelligence:fork_intelligence@localhost:5432/fork_intelligence
FORK_INTELLIGENCE_REDIS_URL=redis://localhost:6379/0

# Optional GitHub authentication. Leave empty for anonymous public access.
FORK_INTELLIGENCE_GITHUB_TOKEN=
FORK_INTELLIGENCE_GITHUB_API_VERSION=2026-03-10

# Analysis limits
FORK_INTELLIGENCE_MAX_FORKS=250
FORK_INTELLIGENCE_MAX_SHORTLIST=12
FORK_INTELLIGENCE_MAX_BRANCHES_PER_FORK=3
FORK_INTELLIGENCE_MAX_ANALYSIS_SECONDS=2700
FORK_INTELLIGENCE_MAX_BLOB_BYTES=1048576
FORK_INTELLIGENCE_MAX_GIT_STORE_BYTES=5368709120
FORK_INTELLIGENCE_MAX_REQUEST_BODY_BYTES=65536
FORK_INTELLIGENCE_MAX_ACTIVE_ANALYSES=10
FORK_INTELLIGENCE_ANALYSIS_REQUESTS_PER_MINUTE=10
FORK_INTELLIGENCE_MIN_GIT_FREE_BYTES=1000000000
FORK_INTELLIGENCE_ANALYSIS_RETENTION_DAYS=30
FORK_INTELLIGENCE_EXPORT_RETENTION_DAYS=7

# Optional AI enrichment is disabled for the MVP.
FORK_INTELLIGENCE_AI_ENABLED=false
